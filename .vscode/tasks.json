{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Operator Debugging",
      "type": "shell",
      "command": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "dependsOrder": "sequence",
      "dependsOn": [
        "Scale-In Operator Pods",
        "Start port-forward RestApi"
      ]
    },
    {
      "label": "Revert Operator Debugging",
      "type": "shell",
      "command": "",
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "dependsOrder": "sequence",
      "dependsOn": [
        "Stop port-forward RestApi"
      ]
    },
    {
      "label": "Start port-forward RestApi",
      "type": "shell",
      "command": "until kubectl -n slurm port-forward deployments/slurm-restapi 6820:6820 ; do sleep 2 ; done",
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": "^([^\\\\s].*)\\\\((\\\\d+,\\\\d+)\\\\):\\\\s*(.*)$",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": {
              "regexp": "Forwarding from"
            },
            "endsPattern": {
              "regexp": "Forwarding from"
            }
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Stop port-forward RestApi",
      "type": "shell",
      "command": "pkill -f 'kubectl -n slurm port-forward deployments/slurm-restapi 6820:6820' 2>/dev/null || true"
    },
    {
      "label": "Scale-In Operator Pods",
      "type": "shell",
      "command": "kubectl -n slinky scale deployment/slurm-operator --replicas 0 || true",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
