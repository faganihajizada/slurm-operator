    webhooks:
      - admissionReviewVersions:
          - v1
        clientConfig:
          service:
            name: slurm-operator-webhook
            namespace: test-namespace
            path: /mutate--v1-binding
        failurePolicy: Ignore
        matchPolicy: Equivalent
        name: podsbinding-v1.kb.io
        namespaceSelector:
          matchExpressions:
            - key: kubernetes.io/metadata.name
              operator: NotIn
              values:
                - kube-system
                - kube-node-lease
                - test-namespace
        rules:
